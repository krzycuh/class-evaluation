# Skopiuj do .env i uzupełnij przed `docker compose up`.

# Hasło bazy danych (wymagane)
DB_PASSWORD=zmien-mnie

# Konto administratora tworzone przy pierwszym starcie.
# Jeśli zostawisz APP_ADMIN_PASSWORD puste, hasło zostanie wygenerowane
# i wypisane w logach backendu (docker compose logs backend).
APP_ADMIN_EMAIL=admin@example.com
APP_ADMIN_PASSWORD=
APP_ADMIN_NAME=Administrator

# Nazwa grupy przedszkolnej tworzonej na starcie
APP_CLASS_GROUP_NAME=Moja grupa

# Port, na którym wystawiamy aplikację
APP_PORT=8000

# Ustaw true, gdy aplikacja stoi za HTTPS (cookie sesji z flagą Secure)
COOKIE_SECURE=false
